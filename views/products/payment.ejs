<% include ./partials/header %>

  <!-- Payment Section -->
  <section id="payment" class="py-5 mt-3">
    <div class="container text-center text-md-left">

      <h2>Payment Terms & Conditions<br />
        Understanding Your Payment Options
      </h2>
      <hr>

      <p class="largerFont mb-1"><strong>Credit Card Payments</strong></p>
      <p class="largerFont">A <strong>3% surcharge</strong> applies to all credit card transactions.</p>

      <p class="largerFont mb-1"><strong>Steps to pay:</strong></p>
      <p class="mb-0 largerFont">• <strong>Enter invoice total:</strong> Type the exact balance due from your invoice. <strong><u>Do not calculate the fee yourself</u></strong>.</p>
      <p class="mb-0 largerFont">• <strong>Review final amount:</strong> The system automatically adds a 3% fee as your final charged amount.</p>
      <p class="mb-0 largerFont">• <strong>Check the box below:</strong> Confirm you accept the 3% fee and are authorized to pay for your company.</p>

      <!-- <p class="largerFont"><strong>If you are paying by credit card via this link,</strong> please note that a 3% credit card surcharge will be <u>automatically</u> applied to this transaction.
        You will <u>enter the invoice total balance amount due</u> onto the payment page (do not calculate the new amount yourself).
        The final 'PAY' value will automatically calculate as the invoice amount x 1.03; this is the new total amount that will be charged to your card.
      </p> -->

      <p class="mt-5 mb-1 largerFont">By checking the box below, you agree to:</p>

      <div class="paymentCheck largerFont">
        <input type="checkbox" name="payment" id="checkbox" />
        <div>
          <p class="agree">I agree to the terms outlined and confirm that I am authorized to accept them on behalf of my company.</p>
        </div>
      </div>

      <div class="paymentAccept largerFont">
        <p class="mt-4 font-weight-bold">As a recap, you are agreeing to:</p>
        <p class="mb-0">• A 3% surcharge, above the invoice total balance due on the invoice, will be processed on the entered card.</p>
        <p>• Accepting these terms on behalf of the company represent, and that I am authorized to accept those terms on behalf of my company.</p>

        <p class="small mt-4 font-weight-bold">To avoid this surcharge, you can pay via ACH/EFT/Wire.</p>
        <p class="small">Payment details can be found on the invoice received.<br />If you need an invoice with details, please email <a class="standard-link" href='mailto:accounting@transtechsys.com'>accounting@transtechsys.com</a> to request this information.
        </p>
        <p class="small font-weight-bold">Thank you for your understanding, cooperation, and continued business partnership.</p>

        <a href="https://api.ipospays.com/v1/sl/KUUiA_180626095352" class="btn paymentLinkBtn mb-2 mt-4" role="button" aria-disabled="true" target="_blank">Continue to Payment Site</a>
      </div>
    </div>

    </div>
  </section>
  <!-- /Payment Section -->

